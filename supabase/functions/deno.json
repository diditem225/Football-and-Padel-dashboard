{
  "compilerOptions": {
    "allowJs": true,
    "lib": ["deno.window"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "jsx": "react-jsx",
    "jsxImportSource": "https://esm.sh/react@18.2.0"
  },
  "imports": {
    "@supabase/supabase-js": "https://esm.sh/@supabase/supabase-js@2.39.3",
    "cors": "https://deno.land/x/cors@v1.2.2/mod.ts",
    "std/": "https://deno.land/std@0.208.0/",
    "sendgrid": "https://esm.sh/@sendgrid/mail@7.7.0",
    "postgres": "https://deno.land/x/postgres@v0.17.0/mod.ts",
    "djwt": "https://deno.land/x/djwt@v3.0.1/mod.ts"
  },
  "tasks": {
    "serve": "deno run --allow-net --allow-env --allow-read --watch",
    "test": "deno test --allow-all",
    "serve-all": "supabase functions serve",
    "deploy-all": "supabase functions deploy"
  },
  "fmt": {
    "options": {
      "useTabs": false,
      "lineWidth": 100,
      "indentWidth": 2,
      "semiColons": true,
      "singleQuote": true,
      "proseWrap": "preserve"
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules/", "dist/", "_shared/"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": ["ban-untagged-todo"]
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules/", "dist/", "_shared/"]
  }
}
