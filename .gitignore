# Root level gitignore

# Environment Variables
.env
.env.local
.env*.local
*.env

# Supabase
.supabase/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker
docker-compose.override.yml

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.next/
out/

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
.cache/

# Kiro
.kiro/specs/*/
!.kiro/specs/.gitkeep
